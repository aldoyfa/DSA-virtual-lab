# Port Configuration
POSTGRES_PORT=15010
BACKEND_PORT=15011
FRONTEND_PORT=15012

# PostgreSQL Database Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=dsa_virtual_lab

# Backend Configuration
DATABASE_URL=postgresql://your_postgres_user:your_postgres_password@postgres:15010/dsa_virtual_lab
NODE_ENV=production
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d

# Frontend Configuration
FRONTEND_URL=http://localhost:15012
VITE_API_URL=http://localhost:15011
